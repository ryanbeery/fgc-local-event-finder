# Copy this file to .env and adjust values as needed.
# .env is git-ignored; .env.example is committed as the template.

# --- Postgres / PostGIS ---
# These are the single source of truth for the database credentials. The Docker
# image consumes POSTGRES_USER/PASSWORD/DB directly on first init; the app and
# Drizzle Kit assemble a connection URL from these parts (see apps/api/src/config).
POSTGRES_USER=fgc
POSTGRES_PASSWORD=change_me_in_local_env
POSTGRES_DB=fgc
# Host port mapped to the container's 5432. Change if 5432 is taken locally.
POSTGRES_PORT=5432
# Where host processes (the app, Drizzle Kit) reach the DB. Locally this is
# 'localhost'. When the API itself runs as a Compose service, override it to the
# service name ('db'). Not consumed by the Postgres container itself.
POSTGRES_HOST=localhost

# --- Optional override ---
# In production (e.g. Coolify) a full connection string is injected here and
# takes precedence over the assembled POSTGRES_* parts. Leave unset locally.
# DATABASE_URL=
