# Copy this file to .env and adjust values as needed.
# .env is git-ignored; .env.example is committed as the template.

# --- Postgres / PostGIS container ---
POSTGRES_USER=fgc
POSTGRES_PASSWORD=change_me_in_local_env
POSTGRES_DB=fgc
# Host port mapped to the container's 5432. Change if 5432 is taken locally.
POSTGRES_PORT=5432

# Connection string for app/tooling (Drizzle, etc.) running on the host.
DATABASE_URL=postgres://fgc:change_me_in_local_env@localhost:5432/fgc
